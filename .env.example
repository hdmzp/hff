# 식품안전나라 OPEN API 설정
# 실제 값은 .env.local 에 작성하세요 (.env.local 은 커밋되지 않습니다)

# 공공데이터포털/식품안전나라에서 발급받은 인증키
FOODSAFETY_API_KEY=

# API 베이스 URL (기본값 그대로 사용)
FOODSAFETY_BASE_URL=http://openapi.foodsafetykorea.go.kr/api

# 각 데이터셋의 serviceId — 비워두면 해당 데이터셋은 샘플 데이터로 동작합니다.
# scripts/test-api.mjs 를 실행하면 serviceId를 자동으로 찾아줍니다.
FSK_SERVICE_INGREDIENT=I2820
FSK_SERVICE_INDIVIDUAL=
FSK_SERVICE_PRODUCT=
FSK_SERVICE_NUTRITION=

# 캐시 유효시간(시간 단위, 기본 24)
CACHE_TTL_HOURS=24

# "1" 로 설정하면 API를 호출하지 않고 항상 샘플 데이터 사용 (데모/개발용)
USE_MOCK_DATA=
